<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portal CPPJ - Cangamba</title>
    
    <!-- Google Fonts & Font Awesome -->
    <link href="https://fonts.googleapis.com" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com">
    
    <style>
        :root {
            --azul-master: #0f172a;
            --dourado: #fbbf24;
            --dourado-glow: rgba(251, 191, 36, 0.3);
            --branco: #f8fafc;
            --azul-card: rgba(30, 41, 59, 0.6);
        }

        body {
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at center, #1e293b 0%, #0f172a 100%);
            color: var(--branco);
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* --- CABEÇALHO --- */
        header { text-align: center; margin-bottom: 30px; }
        .diocese-txt { font-size: 0.8rem; color: var(--dourado); letter-spacing: 4px; font-weight: 700; text-transform: uppercase; margin-bottom: 5px; }
        .paroquia-txt { font-size: 0.65rem; opacity: 0.8; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 20px; }

        /* --- CÍRCULO CENTRAL (FOTO) --- */
        .moldura-foto {
            width: 240px; height: 240px;
            border: 4px solid var(--dourado);
            border-radius: 50%;
            padding: 10px;
            margin-bottom: 40px;
            background: rgba(255, 255, 255, 0.05);
            box-shadow: 0 0 50px var(--dourado-glow);
            transition: 0.5s;
            overflow: hidden;
        }
        .moldura-foto img { width: 100%; height: 100%; border-radius: 50%; object-fit: cover; }
        .moldura-foto:hover { transform: scale(1.05); box-shadow: 0 0 70px var(--dourado); }

        /* --- BARRA DE CONSULTA --- */
        .container-consulta { width: 90%; max-width: 500px; margin-bottom: 30px; }
        .form-consulta {
            display: flex; 
            background: var(--azul-card);
            backdrop-filter: blur(10px);
            padding: 8px; 
            border-radius: 50px; 
            border: 1px solid rgba(251, 191, 36, 0.4);
        }
        .input-consulta { 
            background: transparent; border: none; color: white; 
            padding: 10px 25px; flex: 1; outline: none; font-size: 1rem;
        }
        .btn-lupa { 
            background: var(--dourado); color: var(--azul-master); 
            border: none; width: 50px; height: 50px; border-radius: 50%; 
            cursor: pointer; transition: 0.3s; font-size: 1.2rem;
        }
        .btn-lupa:hover { background: white; transform: scale(1.1); }

        /* --- BOTÃO ACESSO RESTRITO --- */
        .btn-acesso { 
            background: white; color: var(--azul-master);
            text-decoration: none; font-size: 0.75rem; 
            letter-spacing: 3px; padding: 15px 45px; 
            border-radius: 50px; transition: 0.4s;
            text-transform: uppercase; font-weight: 900;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }
        .btn-acesso:hover { transform: translateY(-5px); letter-spacing: 5px; background: var(--dourado); }

        /* --- BOTÃO SUGESTÕES --- */
        .btn-sugestao {
            position: fixed; bottom: 30px; left: 30px;
            background: rgba(15, 23, 42, 0.8); border: 1px solid var(--dourado);
            color: var(--dourado); padding: 12px 25px; border-radius: 50px;
            cursor: pointer; font-size: 0.65rem; font-weight: 800; text-transform: uppercase;
            letter-spacing: 2px; transition: 0.3s;
        }
        .btn-sugestao:hover { background: var(--dourado); color: black; }

        /* --- MURAL LATERAL --- */
        .sinal-noticias {
            position: fixed; right: 0; top: 50%; transform: translateY(-50%);
            background: var(--dourado); color: #000; padding: 30px 12px;
            cursor: pointer; writing-mode: vertical-rl; text-orientation: mixed;
            font-weight: 900; font-size: 10px; border-radius: 20px 0 0 20px; z-index: 1000;
        }
        .sidebar {
            height: 100%; width: 0; position: fixed; z-index: 2000; top: 0; right: 0;
            background-color: #0f172a; overflow-x: hidden; transition: 0.5s;
            box-shadow: -10px 0 50px rgba(0,0,0,0.8);
        }
        .noticia-item { padding: 20px; border-bottom: 1px solid #1e293b; }
    </style>
</head>
<body>

    <!-- BOTÃO LATERAL -->
    <div class="sinal-noticias" onclick="abrirNoticias()">
        MURAL DE NOTÍCIAS
    </div>

    <!-- SIDEBAR DE NOTÍCIAS -->
    <div id="sidebarNoticias" class="sidebar">
        <div style="padding: 30px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #1e293b;">
            <h2 style="color:var(--dourado); margin:0; font-size: 1rem; letter-spacing: 2px;">COMUNICADOS</h2>
            <span style="font-size:30px; cursor:pointer; color:var(--dourado);" onclick="fecharNoticias()">&times;</span>
        </div>
        <div id="conteudoNoticias">
            <% if (noticias && noticias.length > 0) { %>
                <% noticias.forEach(n => { %>
                    <div class="noticia-item">
                        <h4 style="color:var(--dourado); margin:0 0 5px 0;"><%= n.titulo %></h4>
                        <p style="font-size:0.8rem; color:#94a3b8; line-height: 1.4;"><%= n.conteudo %></p>
                        <small style="color:#475569;"><%= n.data %></small>
                    </div>
                <% }) %>
            <% } else { %>
                <p style="text-align:center; opacity:0.3; margin-top:50px;">Nenhum aviso para hoje.</p>
            <% } %>
        </div>
    </div>

    <!-- CONTEÚDO PRINCIPAL -->
    <header>
        <div class="diocese-txt">Diocese do Lwena</div>
        <div class="paroquia-txt">Paróquia de Nossa Senhora Rainha da Paz - Cangamba</div>
        <div class="paroquia-txt" style="font-weight: 800; opacity: 1;">Comissão Paroquial da Pastoral Juvenil</div>
    </header>

    <div class="moldura-foto">
        <img src="/logo-cppj.png" 
             alt="Logo CPPJ" 
             onerror="this.onerror=null; this.src='https://via.placeholder.com'">
    </div>

    <div class="container-consulta">
        <form action="/consultar-registo" method="POST" class="form-consulta">
            <input type="text" name="bi" class="input-consulta" placeholder="Consultar BI ou Nome Completo..." required>
            <button type="submit" class="btn-lupa">
                <i class="fas fa-search"></i>
            </button>
        </form>
    </div>

    <a href="/login" class="btn-acesso">Acesso Restrito</a>

    <button class="btn-sugestao" onclick="alert('Funcionalidade em breve!')">Sugestões</button>

    <script>
        function abrirNoticias() { document.getElementById("sidebarNoticias").style.width = "380px"; }
        function fecharNoticias() { document.getElementById("sidebarNoticias").style.width = "0"; }
    </script>

</body>
</html>
