<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portal CPPJ - Cangamba</title>
    
    <!-- Google Fonts & Font Awesome -->
    <link href="https://fonts.googleapis.com" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com">
    
    <style>
        :root {
            --azul-master: #0f172a;
            --dourado: #fbbf24;
            --dourado-glow: rgba(251, 191, 36, 0.3);
            --branco: #f8fafc;
            --azul-card: rgba(30, 41, 59, 0.6);
        }

        body {
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at center, #1e293b 0%, #0f172a 100%);
            color: var(--branco);
            margin: 0; display: flex; flex-direction: column; align-items: center; justify-content: center;
            min-height: 100vh; overflow-x: hidden;
        }

        header { text-align: center; margin-bottom: 20px; }
        header h1 { font-size: 3rem; letter-spacing: 8px; margin: 0; text-transform: uppercase; font-weight: 800; color: white; }
        .subtitulo { font-size: 0.9rem; color: var(--dourado); letter-spacing: 3px; text-transform: uppercase; }

        /* MOLDURA DA FOTO */
        .moldura-foto {
            width: 200px; height: 200px; border: 4px solid var(--dourado); border-radius: 50%;
            padding: 8px; margin-bottom: 30px; background: rgba(255, 255, 255, 0.05);
            box-shadow: 0 0 40px var(--dourado-glow); overflow: hidden;
        }
        .moldura-foto img { width: 100%; height: 100%; border-radius: 50%; object-fit: cover; }

        /* BARRA DE PESQUISA */
        .container-consulta { width: 100%; max-width: 450px; margin-bottom: 20px; }
        .form-consulta {
            display: flex; background: var(--azul-card); backdrop-filter: blur(10px);
            padding: 6px; border-radius: 50px; border: 1px solid var(--dourado);
        }
        .input-consulta { background: transparent; border: none; color: white; padding: 10px 20px; flex: 1; outline: none; }
        .btn-lupa { background: var(--dourado); color: var(--azul-master); border: none; width: 45px; height: 45px; border-radius: 50%; cursor: pointer; transition: 0.3s; }
        .btn-lupa:hover { transform: scale(1.1); background: white; }

        /* BOTÕES */
        .btn-acesso { color: var(--dourado); text-decoration: none; font-size: 0.75rem; letter-spacing: 2px; border: 1.5px solid var(--dourado); padding: 12px 30px; border-radius: 50px; transition: 0.4s; font-weight: 800; text-transform: uppercase; }
        .btn-acesso:hover { background: white; color: var(--azul-master); }

        .btn-sugestao { position: fixed; bottom: 20px; left: 20px; background: var(--azul-card); border: 1px solid var(--dourado); color: var(--dourado); padding: 12px 20px; border-radius: 50px; cursor: pointer; font-weight: 800; }

        /* MURAL LATERAL */
        .sidebar { height: 100%; width: 0; position: fixed; z-index: 2000; top: 0; right: 0; background-color: #0f172a; overflow-x: hidden; transition: 0.5s; box-shadow: -5px 0 20px rgba(0,0,0,0.5); }
        .sinal-noticias { position: fixed; right: 0; top: 50%; transform: translateY(-50%); background: var(--dourado); color: #000; padding: 20px 10px; cursor: pointer; writing-mode: vertical-rl; font-weight: 800; border-radius: 10px 0 0 10px; }

        /* MODAL */
        .modal { display: none; position: fixed; z-index: 3000; left:0; top:0; width:100%; height:100%; background: rgba(0,0,0,0.8); backdrop-filter: blur(5px); }
        .modal-content { background: #1e293b; margin: 10% auto; padding: 30px; width: 90%; max-width: 350px; border-radius: 20px; border: 1px solid var(--dourado); text-align: center; }
    </style>
</head>
<body>

    <!-- BOTÃO MURAL -->
    <div class="sinal-noticias" onclick="abrirNoticias()">
        <i class="fas fa-bullhorn"></i> MURAL DE NOTÍCIAS
    </div>

    <!-- SIDEBAR NOTÍCIAS -->
    <div id="sidebarNoticias" class="sidebar">
        <div style="padding: 25px; border-bottom: 1px solid #334155; display: flex; justify-content: space-between;">
            <h3 style="color:var(--dourado); margin:0;">COMUNICADOS</h3>
            <span style="cursor:pointer; font-size:25px; color:white;" onclick="fecharNoticias()">&times;</span>
        </div>
        <div style="padding: 20px;">
            <% if (noticias.length > 0) { %>
                <% noticias.forEach(n => { %>
                    <div style="margin-bottom: 20px; border-bottom: 1px solid #1e293b; padding-bottom: 10px;">
                        <h4 style="color:var(--dourado); margin:0;"><%= n.titulo %></h4>
                        <p style="font-size:0.85rem; color:#ccc;"><%= n.conteudo %></p>
                        <small style="color: #64748b;"><%= n.data %></small>
                    </div>
                <% }) %>
            <% } else { %>
                <p style="text-align:center; opacity:0.5;">Nenhuma notícia hoje.</p>
            <% } %>
        </div>
    </div>

    <!-- CABEÇALHO -->
    <header>
        <div class="subtitulo">Diocese do Lwena</div>
        <h1>CPPJ</h1>
        <div style="font-size: 0.7rem; opacity: 0.6; letter-spacing: 3px; font-weight: bold;">PARÓQUIA RAINHA DA PAZ - CANGAMBA</div>
    </header>

    <!-- FOTO INTERATIVA -->
    <div class="moldura-foto">
        <img src="/jovens.jpg" alt="Logo CPPJ" onerror="this.src='https://via.placeholder.com'">
    </div>

    <!-- BARRA DE CONSULTA -->
    <div class="container-consulta">
        <form action="/consultar" method="POST" class="form-consulta">
            <input type="text" name="termo" class="input-consulta" placeholder="Pesquisar Membro (Nome ou BI)..." required>
            <button type="submit" class="btn-lupa">
                <i class="fas fa-search"></i>
            </button>
        </form>
    </div>

    <div style="margin-top: 20px;">
        <a href="/login" class="btn-acesso"><i class="fas fa-lock"></i> Acesso Restrito</a>
    </div>

    <button class="btn-sugestao" onclick="abrirModal('modalSugestao')">
        <i class="fas fa-comment-dots"></i> Sugestões
    </button>

    <!-- MODAL SUGESTÃO -->
    <div id="modalSugestao" class="modal">
        <div class="modal-content">
            <h3 style="color:var(--dourado);">Enviar Sugestão</h3>
            <form action="/enviar-sugestao" method="POST">
                <textarea name="mensagem" placeholder="Escreve aqui..." required style="width:100%; height:100px; border-radius:10px; padding:10px; margin-bottom:10px; background:#0f172a; color:white; border:1px solid #333;"></textarea>
                <button type="submit" class="btn-acesso" style="width:100%; cursor:pointer;">Enviar Agora</button>
                <button type="button" onclick="fecharModais()" style="background:none; border:none; color:gray; margin-top:10px; cursor:pointer;">Cancelar</button>
            </form>
        </div>
    </div>

    <script>
        function abrirNoticias() { document.getElementById("sidebarNoticias").style.width = "320px"; }
        function fecharNoticias() { document.getElementById("sidebarNoticias").style.width = "0"; }
        function abrirModal(id) { document.getElementById(id).style.display = "block"; }
        function fecharModais() { document.querySelectorAll('.modal').forEach(m => m.style.display = 'none'); }
        window.onclick = function(e) { if (e.target.className === 'modal') fecharModais(); }
    </script>
</body>
</html>
