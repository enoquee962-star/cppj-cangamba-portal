<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portal CPPJ - Cangamba</title>
    
    <!-- Google Fonts & Font Awesome -->
    <link href="https://fonts.googleapis.com" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com">
    
    <style>
        :root {
            --azul-master: #0f172a;
            --azul-escuro: #0a0e1a;
            --dourado: #fbbf24;
            --dourado-glow: rgba(251, 191, 36, 0.3);
            --branco: #f8fafc;
            --azul-card: rgba(30, 41, 59, 0.6);
        }

        body {
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at center, #1e293b 0%, #0f172a 100%);
            color: var(--branco);
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* --- CABEÇALHO E ANIMAÇÕES DE TEXTO --- */
        header { text-align: center; }

        header h1 {
            font-size: 3.5rem; 
            letter-spacing: 10px; 
            margin: 0;
            text-transform: uppercase; 
            font-weight: 800;
            text-shadow: 0 10px 30px rgba(0,0,0,0.5);
            transition: all 0.4s ease;
            display: inline-block;
        }

        header h1:hover {
            transform: translateY(-5px);
            color: var(--dourado);
            text-shadow: 0 0 25px var(--dourado-glow);
        }

        .subtitulo {
            font-size: 0.9rem; 
            color: var(--dourado);
            margin: 10px 0 5px 0; 
            letter-spacing: 3px;
            text-transform: uppercase;
            font-weight: 600;
            transition: all 0.4s ease;
        }

        .comissao-tag {
            font-size: 0.7rem;
            color: var(--branco);
            opacity: 0.8;
            letter-spacing: 4px;
            font-weight: 700;
            margin-bottom: 40px;
            text-transform: uppercase;
            animation: brilhoLento 3s infinite ease-in-out;
            transition: all 0.4s ease;
        }

        .subtitulo:hover, .comissao-tag:hover {
            color: white;
            letter-spacing: 5px;
            opacity: 1;
        }

        @keyframes brilhoLento {
            0%, 100% { opacity: 0.6; }
            50% { opacity: 1; text-shadow: 0 0 10px rgba(255,255,255,0.3); }
        }

        /* --- MOLDURA DA FOTO INTERATIVA --- */
        .moldura-foto {
            width: 220px; height: 220px;
            border: 4px solid var(--dourado);
            border-radius: 50%;
            padding: 10px;
            margin-bottom: 40px;
            background: rgba(255, 255, 255, 0.05);
            box-shadow: 0 0 50px var(--dourado-glow);
            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            overflow: hidden;
        }

        .moldura-foto img { width: 100%; height: 100%; border-radius: 50%; object-fit: cover; }

        .moldura-foto:hover {
            transform: scale(1.08) rotate(3deg);
            box-shadow: 0 0 70px var(--dourado);
            border-color: white;
        }

        /* --- BARRA DE PESQUISA --- */
        .container-consulta { width: 100%; max-width: 500px; margin-bottom: 25px; }
        .form-consulta {
            display: flex; 
            background: var(--azul-card);
            backdrop-filter: blur(10px);
            padding: 8px; 
            border-radius: 50px; 
            border: 1px solid rgba(251, 191, 36, 0.4);
            transition: 0.3s;
        }

        .form-consulta:focus-within { border-color: white; box-shadow: 0 0 20px rgba(255,255,255,0.1); }

        .input-consulta { 
            background: transparent; border: none; color: white; 
            padding: 10px 25px; flex: 1; outline: none; font-size: 1rem;
        }

        .btn-lupa { 
            background: var(--dourado); color: var(--azul-master); 
            border: none; width: 50px; height: 50px; border-radius: 50%; 
            cursor: pointer; transition: all 0.3s ease; font-size: 1.2rem;
        }

        .btn-lupa:hover { background: white; transform: scale(1.1) rotate(15deg); }

        /* --- BOTÕES COM ANIMAÇÃO DE LEVITAÇÃO --- */
        .btn-acesso { 
            color: var(--dourado); text-decoration: none; font-size: 0.7rem; 
            letter-spacing: 2px; border: 1.5px solid var(--dourado); 
            padding: 12px 35px; border-radius: 50px; transition: all 0.4s ease;
            text-transform: uppercase; font-weight: 800;
            display: inline-block;
        }

        .btn-acesso:hover { 
            background: white; color: var(--azul-master); 
            box-shadow: 0 10px 25px rgba(255, 255, 255, 0.2); 
            transform: translateY(-5px);
            letter-spacing: 4px;
        }

        .btn-sugestao {
            position: fixed; bottom: 30px; left: 30px;
            background: var(--azul-card); border: 1px solid var(--dourado);
            color: var(--dourado); padding: 15px 25px; border-radius: 50px;
            cursor: pointer; font-weight: 800; backdrop-filter: blur(10px);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            z-index: 1000;
        }

        .btn-sugestao:hover { 
            background: var(--dourado); color: #000; 
            transform: scale(1.1) translateY(-10px);
            box-shadow: 0 15px 30px rgba(251, 191, 36, 0.4);
        }

        /* --- MURAL LATERAL --- */
        .sidebar {
            height: 100%; width: 0; position: fixed; z-index: 2000; top: 0; right: 0;
            background-color: #0f172a; overflow-x: hidden; transition: 0.5s;
            box-shadow: -10px 0 40px rgba(0,0,0,0.8);
        }

        .sinal-noticias {
            position: fixed; right: 0; top: 50%; transform: translateY(-50%);
            background: var(--dourado); color: #000; padding: 25px 12px;
            cursor: pointer; writing-mode: vertical-rl; text-orientation: mixed;
            font-weight: 800; font-size: 11px; border-radius: 15px 0 0 15px; z-index: 1000;
            transition: 0.3s;
        }
        .sinal-noticias:hover { padding-right: 20px; background: white; }

        /* --- MODAIS --- */
        .modal { display: none; position: fixed; z-index: 3000; left:0; top:0; width:100%; height:100%; background: rgba(0,0,0,0.9); backdrop-filter: blur(10px); }
        .modal-content { background: #1e293b; margin: 10% auto; padding: 30px; width: 90%; max-width: 400px; border-radius: 20px; border: 1px solid var(--dourado); text-align: center; }
    </style>
</head>
<body>

    <!-- BOTÃO LATERAL MURAL -->
    <div class="sinal-noticias" onclick="abrirNoticias()">
        <i class="fas fa-bullhorn"></i> MURAL CPPJ CANGAMBA
    </div>

    <!-- SIDEBAR COMUNICADOS -->
    <div id="sidebarNoticias" class="sidebar">
        <div style="padding: 30px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #1e293b;">
            <h2 style="color:var(--dourado); margin:0; font-size: 1.2rem;">MURAL OFICIAL</h2>
            <span style="font-size:30px; cursor:pointer; color:var(--dourado);" onclick="fecharNoticias()">&times;</span>
        </div>
        <div style="padding: 20px;">
            <% if (typeof noticias !== 'undefined' && noticias.length > 0) { %>
                <% noticias.forEach(n => { %>
                    <div style="padding: 15px; border-bottom: 1px solid #1e293b; margin-bottom: 10px; transition: 0.3s;">
                        <h4 style="color:var(--dourado); margin:0 0 5px 0;"><%= n.titulo %></h4>
                        <p style="font-size:0.85rem; color:#ccc;"><%= n.conteudo %></p>
                        <small style="color:#444;"><%= n.data %></small>
                    </div>
                <% }) %>
            <% } else { %>
                <p style="text-align:center; opacity:0.3; margin-top:50px;">Sem comunicados hoje.</p>
            <% } %>
        </div>
    </div>

    <!-- PORTAL PRINCIPAL -->
    <header>
        <h1>BEM-VINDO</h1>
        <div class="subtitulo">Paróquia Nossa Senhora Rainha da Paz - Cangamba</div>
        <div class="comissao-tag">COMISSÃO PAROQUIAL DA PASTORAL JUVENIL</div>
    </header>

    <div class="moldura-foto">
        <img src="/jovens.jpg" alt="Juventude" onerror="this.src='https://via.placeholder.com'">
    </div>

    <div class="container-consulta">
        <form action="/consultar" method="POST" class="form-consulta">
            <input type="text" name="termo" class="input-consulta" placeholder="Nome, BI ou Telefone..." required autocomplete="off">
            <button type="submit" class="btn-lupa"><i class="fas fa-search"></i></button>
        </form>
    </div>

    <a href="/login" class="btn-acesso">ACESSO RESTRITO À COORDENAÇÃO</a>

    <button class="btn-sugestao" onclick="abrirModal('modalSugestao')">
        <i class="fas fa-lightbulb"></i> ENVIAR SUGESTÃO
    </button>

    <!-- MODAL SUGESTÃO -->
    <div id="modalSugestao" class="modal">
        <div class="modal-content">
            <h2 style="color: var(--dourado); margin-top: 0;">Espaço do Jovem</h2>
            <form action="/enviar-sugestao" method="POST">
                <input type="text" name="autor" placeholder="Teu Nome (Opcional)" style="width:100%; padding:12px; margin-bottom:10px; background:#0f172a; border:1px solid #334155; color:white; border-radius:10px;">
                <textarea name="texto" placeholder="Escreve a tua ideia aqui..." required style="width:100%; height:100px; padding:12px; background:#0f172a; border:1px solid #334155; color:white; border-radius:10px; resize:none;"></textarea>
                <button type="submit" style="background:var(--dourado); color:var(--azul-master); border:none; padding:15px; width:100%; border-radius:10px; font-weight:800; margin-top:15px; cursor:pointer;">ENVIAR</button>
                <button type="button" onclick="fecharModais()" style="background:none; border:none; color:#64748b; margin-top:10px; cursor:pointer;">CANCELAR</button>
            </form>
        </div>
    </div>

    <script>
        function abrirNoticias() { document.getElementById("sidebarNoticias").style.width = "350px"; }
        function fecharNoticias() { document.getElementById("sidebarNoticias").style.width = "0"; }
        function abrirModal(id) { document.getElementById(id).style.display = "block"; }
        function fecharModais() { document.querySelectorAll('.modal').forEach(m => m.style.display = 'none'); }

        window.onclick = function(event) {
            if (event.target.className === 'modal') fecharModais();
        }
    </script>

</body>
</html>