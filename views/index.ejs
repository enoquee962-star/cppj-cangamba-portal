<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portal CPPJ - Cangamba</title>
    
    <!-- Google Fonts & Font Awesome -->
    <link href="https://fonts.googleapis.com" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com">
    
    <style>
        :root {
            --azul-master: #0f172a;
            --dourado: #fbbf24;
            --dourado-glow: rgba(251, 191, 36, 0.3);
            --branco: #f8fafc;
            --azul-card: rgba(30, 41, 59, 0.6);
        }

        body {
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at center, #1e293b 0%, #0f172a 100%);
            color: var(--branco);
            margin: 0; display: flex; flex-direction: column; align-items: center; justify-content: center;
            min-height: 100vh; overflow-x: hidden;
        }

        header { text-align: center; margin-bottom: 20px; }
        header h1 { font-size: 3.5rem; letter-spacing: 10px; margin: 0; text-transform: uppercase; font-weight: 800; color: white; }
        .subtitulo { font-size: 0.85rem; color: var(--dourado); letter-spacing: 3px; text-transform: uppercase; font-weight: 600; margin-bottom: 5px; }
        
        .paroquia-nome { font-size: 0.75rem; color: white; letter-spacing: 2px; text-transform: uppercase; font-weight: 700; margin-top: 8px; opacity: 0.9; }
        .cppj-extenso { font-size: 0.65rem; color: var(--dourado); letter-spacing: 3px; text-transform: uppercase; font-weight: 600; margin-top: 5px; }

        /* MOLDURA DA FOTO (COMO NA IMAGEM) */
        .moldura-foto {
            width: 220px; height: 220px; border: 4px solid var(--dourado); border-radius: 50%;
            padding: 10px; margin: 25px 0; background: rgba(255, 255, 255, 0.05);
            box-shadow: 0 0 50px var(--dourado-glow); overflow: hidden;
            transition: 0.4s;
        }
        .moldura-foto img { width: 100%; height: 100%; border-radius: 50%; object-fit: cover; }
        .moldura-foto:hover { transform: scale(1.05); box-shadow: 0 0 60px var(--dourado); }

        /* BARRA DE PESQUISA */
        .container-consulta { width: 100%; max-width: 480px; margin-bottom: 25px; }
        .form-consulta {
            display: flex; background: var(--azul-card); backdrop-filter: blur(15px);
            padding: 8px; border-radius: 50px; border: 1px solid rgba(251, 191, 36, 0.4);
            transition: 0.3s;
        }
        .form-consulta:focus-within { border-color: white; box-shadow: 0 0 20px rgba(255,255,255,0.1); }
        .input-consulta { background: transparent; border: none; color: white; padding: 12px 25px; flex: 1; outline: none; font-size: 1rem; }
        .btn-lupa { background: var(--dourado); color: var(--azul-master); border: none; width: 50px; height: 50px; border-radius: 50%; cursor: pointer; transition: 0.3s; font-size: 1.2rem; }
        .btn-lupa:hover { background: white; transform: scale(1.1); }

        /* BOTÃO ACESSO RESTRITO */
        .btn-acesso { 
            background: white; color: var(--azul-master); text-decoration: none; 
            font-size: 0.75rem; letter-spacing: 2px; padding: 14px 45px; 
            border-radius: 50px; transition: 0.4s; font-weight: 800; 
            text-transform: uppercase; display: inline-block; margin-top: 10px;
        }
        .btn-acesso:hover { background: var(--dourado); transform: translateY(-3px); box-shadow: 0 10px 25px rgba(251, 191, 36, 0.3); }

        /* MURAL DE NOTÍCIAS (LATERAL) */
        .sinal-noticias { 
            position: fixed; right: 0; top: 50%; transform: translateY(-50%); 
            background: var(--dourado); color: #000; padding: 25px 12px; 
            cursor: pointer; writing-mode: vertical-rl; text-orientation: mixed;
            font-weight: 800; font-size: 12px; border-radius: 15px 0 0 15px; z-index: 1000;
        }
        .sidebar { height: 100%; width: 0; position: fixed; z-index: 2000; top: 0; right: 0; background-color: #0f172a; overflow-x: hidden; transition: 0.5s; box-shadow: -10px 0 40px rgba(0,0,0,0.8); }

        /* BOTÃO SUGESTÕES */
        .btn-sugestao { position: fixed; bottom: 30px; left: 30px; background: none; border: 1px solid var(--dourado); color: var(--dourado); padding: 12px 25px; border-radius: 50px; cursor: pointer; font-weight: 700; font-size: 0.7rem; text-transform: uppercase; transition: 0.3s; }
        .btn-sugestao:hover { background: var(--dourado); color: black; }

        /* MODAL */
        .modal { display: none; position: fixed; z-index: 3000; left:0; top:0; width:100%; height:100%; background: rgba(0,0,0,0.9); backdrop-filter: blur(10px); }
        .modal-content { background: #1e293b; margin: 10% auto; padding: 30px; width: 90%; max-width: 400px; border-radius: 25px; border: 1px solid var(--dourado); text-align: center; }
    </style>
</head>
<body>

    <!-- BOTÃO MURAL -->
    <div class="sinal-noticias" onclick="abrirNoticias()">
        <i class="fas fa-bullhorn"></i> MURAL DE NOTÍCIAS
    </div>

    <!-- SIDEBAR NOTÍCIAS -->
    <div id="sidebarNoticias" class="sidebar">
        <div style="padding: 30px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #1e293b;">
            <h2 style="color:var(--dourado); margin:0; font-size: 1.2rem;">COMUNICADOS</h2>
            <span style="font-size:30px; cursor:pointer; color:white;" onclick="fecharNoticias()">&times;</span>
        </div>
        <div style="padding: 20px;">
            <% if (noticias.length > 0) { %>
                <% noticias.forEach(n => { %>
                    <div style="padding: 15px; border-bottom: 1px solid #1e293b; margin-bottom: 10px;">
                        <h4 style="color:var(--dourado); margin:0 0 5px 0;"><%= n.titulo %></h4>
                        <p style="font-size:0.85rem; color:#ccc;"><%= n.conteudo %></p>
                        <small style="color:#64748b;"><%= n.data %></small>
                    </div>
                <% }) %>
            <% } else { %>
                <p style="text-align:center; opacity:0.3; margin-top:50px;">Nenhuma notícia publicada.</p>
            <% } %>
        </div>
    </div>

    <!-- CABEÇALHO (HIERARQUIA SOLICITADA) -->
    <header>
        <div class="subtitulo">Diocese do Lwena</div>
        <h1>CPPJ</h1>
        <div class="paroquia-nome">Paróquia de Nossa Senhora Rainha da Paz - Cangamba</div>
        <div class="cppj-extenso">Comissão Paroquial da Pastoral Juvenil</div>
    </header>

    <!-- MOLDURA DO LOGO -->
    <div class="moldura-foto">
        <img src="/jovens.jpg" alt="Logo CPPJ" onerror="this.src='https://via.placeholder.com'">
    </div>

    <!-- BARRA DE CONSULTA -->
    <div class="container-consulta">
        <form action="/consultar" method="POST" class="form-consulta">
            <input type="text" name="termo" class="input-consulta" placeholder="Consultar BI ou Nome Completo..." required>
            <button type="submit" class="btn-lupa">
                <i class="fas fa-search"></i>
            </button>
        </form>
    </div>

    <!-- BOTÃO LOGIN -->
    <div>
        <a href="/login" class="btn-acesso">ACESSO RESTRITO</a>
    </div>

    <!-- SUGESTÕES -->
    <button class="btn-sugestao" onclick="abrirModal('modalSugestao')">Sugestões</button>

    <!-- MODAL SUGESTÃO -->
    <div id="modalSugestao" class="modal">
        <div class="modal-content">
            <h3 style="color:var(--dourado); margin-top:0;">Enviar Sugestão</h3>
            <form action="/enviar-sugestao" method="POST">
                <textarea name="mensagem" placeholder="A sua opinião é importante para nós..." required style="width:100%; height:120px; border-radius:15px; padding:15px; background:#0f172a; color:white; border:1px solid #333; font-family:inherit; resize:none; outline:none; box-sizing:border-box;"></textarea>
                <button type="submit" class="btn-acesso" style="width:100%; margin-top:15px; cursor:pointer; border:none;">Enviar Agora</button>
                <button type="button" onclick="fecharModais()" style="background:none; border:none; color:#64748b; margin-top:10px; cursor:pointer; font-weight:bold;">Cancelar</button>
            </form>
        </div>
    </div>

    <script>
        function abrirNoticias() { document.getElementById("sidebarNoticias").style.width = "350px"; }
        function fecharNoticias() { document.getElementById("sidebarNoticias").style.width = "0"; }
        function abrirModal(id) { document.getElementById(id).style.display = "block"; }
        function fecharModais() { document.querySelectorAll('.modal').forEach(m => m.style.display = 'none'); }
        window.onclick = function(event) { if (event.target.className === 'modal') fecharModais(); }
    </script>
</body>
</html>
