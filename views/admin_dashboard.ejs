<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel de Controlo - CPPJ Cangamba</title>
    
    <!-- Google Fonts & Font Awesome -->
    <link href="https://fonts.googleapis.com" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com">

    <style>
        :root {
            --azul-master: #0f172a;
            --azul-card: rgba(30, 41, 59, 0.7);
            --dourado: #fbbf24;
            --branco: #f8fafc;
            --perigo: #ef4444;
            --sucesso: #22c55e;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at top right, #1e293b, #0f172a);
            color: var(--branco);
            margin: 0; padding: 40px 20px; min-height: 100vh;
        }

        .container { max-width: 1200px; margin: auto; }

        /* CABEÇALHO */
        .header-premium { text-align: center; margin-bottom: 40px; position: relative; }
        .profile-img { width: 90px; height: 90px; border: 3px solid var(--dourado); border-radius: 50%; margin-bottom: 15px; object-fit: cover; }
        .btn-logout { position: absolute; top: 0; right: 0; color: #ff7675; text-decoration: none; font-weight: bold; font-size: 0.7rem; border: 1px solid #ff7675; padding: 8px 15px; border-radius: 50px; transition: 0.3s; }
        .btn-logout:hover { background: #ff7675; color: white; }

        /* ESTATÍSTICAS */
        .stats-bar { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 30px; }
        .stat-item { background: rgba(255,255,255,0.05); padding: 20px; border-radius: 15px; text-align: center; border: 1px solid rgba(255,255,255,0.1); transition: 0.3s; }
        .stat-item:hover { transform: translateY(-5px); border-color: var(--dourado); }
        .stat-item i { color: var(--dourado); display: block; font-size: 1.5rem; margin-bottom: 10px; }
        .stat-item span { font-size: 1.6rem; font-weight: 900; display: block; }
        .stat-item label { font-size: 0.65rem; text-transform: uppercase; color: #94a3b8; letter-spacing: 1px; }

        /* MENU DE ACÇÕES */
        .grid-menu { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 15px; margin-bottom: 40px; }
        .card-link {
            background: var(--azul-card); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.1);
            padding: 25px 10px; border-radius: 20px; text-decoration: none; color: white; text-align: center; transition: 0.3s;
            cursor: pointer; display: flex; flex-direction: column; align-items: center; gap: 10px;
        }
        .card-link:hover { transform: translateY(-5px); border-color: var(--dourado); box-shadow: 0 10px 30px rgba(0,0,0,0.3); }
        .card-link i { font-size: 1.8rem; color: var(--dourado); }
        .card-link span { font-weight: 700; text-transform: uppercase; font-size: 0.65rem; letter-spacing: 1px; }

        /* SECÇÃO DE MOVIMENTOS RECENTES */
        .data-box { background: rgba(15, 23, 42, 0.8); border-radius: 22px; padding: 25px; border: 1px solid rgba(251, 191, 36, 0.1); }
        .scroll-area { max-height: 350px; overflow-y: auto; margin-top: 15px; }
        .item-mov { 
            background: rgba(255,255,255,0.03); padding: 15px; border-radius: 12px; 
            margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center;
        }
        .badge-entrada { color: var(--sucesso); font-weight: 800; }
        .badge-saida { color: var(--perigo); font-weight: 800; }

        /* MODAIS */
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); backdrop-filter: blur(10px); z-index: 9999; }
        .modal-content { background: #1e293b; width: 90%; max-width: 400px; margin: 10% auto; padding: 30px; border-radius: 25px; border: 1px solid var(--dourado); }
        input, select { width: 100%; padding: 14px; margin-bottom: 15px; background: #0f172a; border: 1px solid #333; border-radius: 10px; color: white; box-sizing: border-box; }
        .btn-acao { background: var(--dourado); color: var(--azul-master); border: none; padding: 15px; width: 100%; border-radius: 10px; font-weight: 900; cursor: pointer; text-transform: uppercase; }
    </style>
</head>
<body>

    <div class="container">
        
        <!-- CABEÇALHO -->
        <div class="header-premium">
            <a href="/logout" class="btn-logout"><i class="fas fa-sign-out-alt"></i> SAIR</a>
            <img src="/logo-cppj.png" class="profile-img" onerror="this.src='https://via.placeholder.com'">
            <h1 style="font-weight: 900; margin: 5px 0;"><%= user.nome %></h1>
            <p style="color: var(--dourado); letter-spacing: 3px; font-size: 0.65rem; text-transform: uppercase;">
                <%= user.tipo %> - CPPJ CANGAMBA
            </p>
        </div>

        <!-- BARRA DE ESTATÍSTICAS -->
        <div class="stats-bar">
            <div class="stat-item">
                <i class="fas fa-users"></i>
                <span><%= stats.crismados + stats.naoCrismados %></span>
                <label>Total Membros</label>
            </div>
            <div class="stat-item">
                <i class="fas fa-dove"></i>
                <span><%= stats.crismados %></span>
                <label>Crismados</label>
            </div>
            <div class="stat-item">
                <i class="fas fa-venus-mars"></i>
                <span><%= stats.feminino %>F / <%= stats.masculino %>M</span>
                <label>Género</label>
            </div>
        </div>

        <!-- MENU DE ACÇÕES -->
        <div class="grid-menu">
            <a href="/cadastro" class="card-link"><i class="fas fa-user-plus"></i><span>Novo Registo</span></a>
            <a href="/admin-lista" class="card-link"><i class="fas fa-address-book"></i><span>Lista Geral</span></a>
            <div onclick="abrirModal('modalFinancas')" class="card-link"><i class="fas fa-sack-dollar"></i><span>Tesouraria</span></div>
            <a href="/relatorio-financeiro" class="card-link"><i class="fas fa-file-invoice-dollar"></i><span>Relatório</span></a>
            
            <% if (user.tipo === 'coordenador') { %>
                <a href="/gestao-acessos" class="card-link"><i class="fas fa-user-shield"></i><span>Gestão Acessos</span></a>
                <a href="/historico-auditoria" class="card-link"><i class="fas fa-shield-halved"></i><span>Auditoria</span></a>
            <% } %>
        </div>

        <!-- MOVIMENTOS RECENTES -->
        <div class="data-box">
            <h3 style="margin-top:0; font-size: 0.9rem; color: var(--dourado); text-transform: uppercase; letter-spacing: 2px;">
                <i class="fas fa-clock-rotate-left"></i> Últimos Movimentos de Caixa
            </h3>
            <div class="scroll-area">
                <% if (financas_lista && financas_lista.length > 0) { %>
                    <% financas_lista.slice(0, 10).forEach(f => { %>
                        <div class="item-mov">
                            <div>
                                <strong><%= f.jovem %></strong><br>
                                <small style="opacity: 0.5;"><%= f.data %> - <%= f.tipo %></small>
                            </div>
                            <div class="<%= f.categoria === 'Entrada' ? 'badge-entrada' : 'badge-saida' %>">
                                <%= f.categoria === 'Entrada' ? '+' : '-' %> <%= parseFloat(f.valor).toLocaleString() %> Kz
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p style="text-align:center; opacity:0.3; padding: 20px;">Sem movimentações recentes.</p>
                <% } %>
            </div>
        </div>
    </div>

    <!-- MODAL TESOURARIA (ENTRADAS E SAÍDAS) -->
    <div id="modalFinancas" class="modal">
        <div class="modal-content">
            <h3 style="color: var(--dourado); margin-top: 0; text-align: center;">Registar Movimento</h3>
            <form action="/adicionar-financa" method="POST">
                <label style="font-size: 0.6rem; color: #aaa;">CATEGORIA</label>
                <select name="categoria" required>
                    <option value="Entrada">✚ Entrada (Recebimento)</option>
                    <option value="Saída">− Saída (Pagamento/Gasto)</option>
                </select>

                <input type="text" name="jovem" placeholder="Membro ou Descrição do Gasto" required>
                <input type="number" name="valor" placeholder="Valor em Kz" required>
                
                <label style="font-size: 0.6rem; color: #aaa;">TIPO DE DOCUMENTO</label>
                <select name="tipo">
                    <option value="Quota Mensal">Quota Mensal</option>
                    <option value="Inscrição">Inscrição</option>
                    <option value="Material de Apoio">Material de Apoio</option>
                    <option value="Evento/Atividade">Evento/Atividade</option>
                    <option value="Outro">Outro</option>
                </select>

                <input type="tel" name="telefone" placeholder="Telefone para Recibo (Opcional)">

                <button type="submit" class="btn-acao">Confirmar Lançamento</button>
                <button type="button" onclick="fecharModal('modalFinancas')" style="background:transparent; color:gray; border:none; width:100%; margin-top:10px; cursor:pointer;">Cancelar</button>
            </form>
        </div>
    </div>

    <script>
        function abrirModal(id) { document.getElementById(id).style.display = 'block'; }
        function fecharModal(id) { document.getElementById(id).style.display = 'none'; }
        window.onclick = function(e) { if (e.target.className === 'modal') e.target.style.display = 'none'; }
    </script>

</body>
</html>
