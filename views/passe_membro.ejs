<!-- FRENTE DO CARTÃO (No teu ficheiro passe_membro.ejs) -->
<div class="cartao frente">
    <div class="header-cartao" style="text-align: center; border-bottom: 1px solid rgba(251, 191, 36, 0.3); padding-bottom: 5px; margin-bottom: 10px;">
        <span class="diocese" style="font-size: 0.75rem; font-weight: 800; color: #fbbf24; display: block; letter-spacing: 1px;">DIOCESE DE LWENA</span>
        <span class="paroquia" style="font-size: 0.55rem; color: #fff; display: block; text-transform: uppercase; margin: 2px 0;">Paróquia de Nossa Senhora Rainha da Paz - Cangamba</span>
        <!-- NOVO CAMPO ADICIONADO ABAIXO -->
        <span class="comissao" style="font-size: 0.6rem; color: #fbbf24; font-weight: 800; display: block; text-transform: uppercase; letter-spacing: 1px; margin-top: 2px;">Comissão Paroquial da Pastoral Juvenil</span>
    </div>

    <div class="corpo-cartao" style="display: flex; gap: 15px; align-items: flex-start;">
        <div class="foto-box" style="width: 105px; height: 130px; border: 2px solid #fbbf24; background: #000; overflow: hidden; flex-shrink: 0;">
            <% if (typeof fotoEnviada !== 'undefined' && fotoEnviada) { %> 
                <img src="<%= fotoEnviada %>" style="width: 100%; height: 100%; object-fit: cover;"> 
            <% } else { %> 
                <div style="text-align:center; padding-top:40px;"><i class="fas fa-user fa-3x" style="opacity:0.2;"></i></div>
            <% } %>
        </div>
        
        <div class="dados" style="flex: 1; color: white;">
            <div class="campo">
                <span style="font-size: 0.5rem; color: #fbbf24; font-weight: 800; text-transform: uppercase; display: block;">Membro Portador</span>
                <div style="font-size: 0.85rem; font-weight: 600;"><%= j.nome.toUpperCase() %></div>
            </div>
            <div class="campo">
                <span style="font-size: 0.5rem; color: #fbbf24; font-weight: 800; text-transform: uppercase; display: block;">B.I. / Identidade</span>
                <div style="font-size: 0.75rem;"><%= j.bi %></div>
            </div>
            <div class="campo">
                <span style="font-size: 0.5rem; color: #fbbf24; font-weight: 800; text-transform: uppercase; display: block;">Centro Pastoral</span>
                <div style="font-size: 0.75rem;"><%= j.centro_pastoral %></div>
            </div>
            <div class="campo">
                <span style="font-size: 0.5rem; color: #fbbf24; font-weight: 800; text-transform: uppercase; display: block;">Grupo / Movimento</span>
                <div style="font-size: 0.75rem;"><%= j.grupo_movimento || 'Sem Grupo' %></div>
            </div>
        </div>
    </div>
    <div style="position:absolute; bottom:10px; right:15px; font-size:0.45rem; color:#fbbf24;">ID: <%= j.id %></div>
</div>
