<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Passe Oficial - <%= j.nome %></title>
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com">
    
    <style>
        :root {
            --azul-master: #0f172a;
            --dourado: #fbbf24;
            --branco: #f8fafc;
        }

        body { 
            background: #f0f0f0; 
            display: flex; 
            flex-direction: column; 
            align-items: center; 
            padding: 40px 20px; 
            font-family: 'Inter', sans-serif; 
            margin: 0;
        }
        
        .folha-impressao { display: flex; flex-direction: column; gap: 40px; align-items: center; }
        
        /* --- ESTRUTURA DO CARTÃO --- */
        .cartao { 
            width: 450px; 
            height: 280px; 
            border-radius: 18px; 
            position: relative; 
            border: 3px solid var(--dourado); 
            overflow: hidden; 
            box-shadow: 0 15px 35px rgba(0,0,0,0.3);
            box-sizing: border-box;
        }
        
        /* --- FRENTE (AZUL DARK) --- */
        .frente { 
            background: linear-gradient(135deg, var(--azul-master) 0%, #0a0e1a 100%); 
            color: white; 
            padding: 15px; 
            display: flex;
            flex-direction: column;
        }
        
        .header-cartao { 
            text-align: center; 
            border-bottom: 1px solid rgba(251, 191, 36, 0.3); 
            padding-bottom: 8px; 
            margin-bottom: 12px; 
        }
        .diocese { font-size: 0.8rem; font-weight: 900; color: var(--dourado); display: block; letter-spacing: 2px; text-transform: uppercase; }
        .paroquia { font-size: 0.55rem; color: #fff; display: block; text-transform: uppercase; margin: 2px 0; opacity: 0.9; }
        .comissao { font-size: 0.6rem; color: var(--dourado); font-weight: 800; display: block; text-transform: uppercase; letter-spacing: 1px; margin-top: 2px; }

        .corpo-cartao { display: flex; gap: 20px; align-items: flex-start; }
        
        .foto-box { 
            width: 105px; height: 130px; 
            border: 2px solid var(--dourado); 
            background: #000; 
            overflow: hidden; 
            flex-shrink: 0; 
            display: flex; align-items: center; justify-content: center; 
        }
        .foto-box img { width: 100%; height: 100%; object-fit: cover; }

        .dados { flex: 1; }
        .campo { margin-bottom: 8px; }
        .label { font-size: 0.5rem; color: var(--dourado); font-weight: 800; text-transform: uppercase; display: block; margin-bottom: 1px; }
        .valor { font-size: 0.8rem; font-weight: 600; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 2px; line-height: 1.2; }

        /* --- VERSO (BRANCO) --- */
        .verso { background: white; color: var(--azul-master); padding: 30px; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; }
        .marca-dagua { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); opacity: 0.04; color: var(--azul-master); z-index: 0; }
        
        .regras { font-size: 0.65rem; line-height: 1.6; color: #333; margin-bottom: 25px; position: relative; z-index: 1; }
        
        .assinatura-area { position: relative; z-index: 1; width: 100%; margin-top: 10px; }
        .linha { width: 200px; border-top: 1.5px solid var(--azul-master); margin: 0 auto 5px auto; }
        .cargo { font-size: 0.65rem; font-weight: 900; text-transform: uppercase; color: var(--azul-master); }

        .btn-print { 
            margin-top: 30px; padding: 15px 40px; 
            background: var(--azul-master); color: white; 
            border: 2px solid var(--dourado); border-radius: 50px; 
            cursor: pointer; font-weight: 800; transition: 0.3s; 
            text-transform: uppercase; letter-spacing: 1px;
        }
        .btn-print:hover { background: var(--dourado); color: var(--azul-master); transform: translateY(-3px); }

        @media print { 
            .btn-print { display: none; } 
            body { background: white; padding: 0; } 
            .cartao { box-shadow: none; margin: 10px auto; -webkit-print-color-adjust: exact; print-color-adjust: exact; } 
        }
    </style>
</head>
<body>

    <div class="folha-impressao">
        
        <!-- FRENTE DO CARTÃO -->
        <div class="cartao frente">
            <div class="header-cartao">
                <span class="diocese">DIOCESE DE LWENA</span>
                <span class="paroquia">Paróquia de Nossa Senhora Rainha da Paz - Cangamba</span>
                <span class="comissao">Comissão Paroquial da Pastoral Juvenil</span>
            </div>

            <div class="corpo-cartao">
                <div class="foto-box">
                    <% if (typeof fotoEnviada !== 'undefined' && fotoEnviada) { %> 
                        <img src="<%= fotoEnviada %>"> 
                    <% } else { %> 
                        <i class="fas fa-user fa-3x" style="opacity:0.2; color: var(--dourado);"></i> 
                    <% } %>
                </div>
                
                <div class="dados">
                    <div class="campo">
                        <span class="label">Membro Portador</span>
                        <div class="valor"><%= j.nome.toUpperCase() %></div>
                    </div>
                    <div class="campo">
                        <span class="label">B.I. / Identidade</span>
                        <div class="valor"><%= j.bi %></div>
                    </div>
                    <div class="campo">
                        <span class="label">Centro Pastoral</span>
                        <div class="valor"><%= j.centro_pastoral %></div>
                    </div>
                    <div class="campo">
                        <span class="label">Grupo / Movimento</span>
                        <div class="valor"><%= j.grupo_movimento || 'CPPJ GERAL' %></div>
                    </div>
                </div>
            </div>
            <div style="position:absolute; bottom:12px; right:15px; font-size:0.5rem; color:var(--dourado); font-weight: bold;">ID: <%= j.id %></div>
        </div>

        <!-- VERSO DO CARTÃO -->
        <div class="cartao verso">
            <div class="marca-dagua"><i class="fas fa-church fa-9x"></i></div>
            
            <div class="regras">
                <strong style="color: var(--azul-master); letter-spacing: 1px; text-transform: uppercase;">Termos de Utilização</strong><br><br>
                1. Este passe identifica o portador como membro ativo da CPPJ.<br>
                2. É pessoal, intransmissível e de uso obrigatório em atividades oficiais.<br>
                3. Em caso de extravio, informe a secretaria paroquial.<br>
                4. Válido enquanto o membro estiver em comunhão com a Paróquia.
            </div>

            <div class="assinatura-area">
                <div class="linha"></div>
                <span class="cargo">O Coordenador Paroquial</span><br>
                <span style="font-size: 0.6rem; color: #555;">Elias Mussole Enoque</span>
            </div>
        </div>

    </div>

    <button class="btn-print" onclick="window.print()">
        <i class="fas fa-print"></i> Imprimir Passe Oficial
    </button>

</body>
</html>
